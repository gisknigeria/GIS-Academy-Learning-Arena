generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TRAINING_MANAGER
  TRAINER
  STUDENT
  CORPORATE_CLIENT
  SCHOOL_COORDINATOR
  OLYMPIAD_COORDINATOR
  EXAMINER
  JUDGE
  GUEST
  ALUMNI
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  OVERDUE
  BLOCKED
}

enum DeliveryMode {
  E_LEARNING
  ONSITE
  LIVE_VIRTUAL
  HYBRID
}

enum CompetitionMode {
  INDIVIDUAL
  HEAD_TO_HEAD
  TEAM
  SCHOOL
  CORPORATE
  LIVE_TIMED
  OPEN_CHALLENGE
  OLYMPIAD
}

enum CompetitionStatus {
  DRAFT
  OPEN
  LIVE
  COMPLETED
  ARCHIVED
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  phone        String?      @unique
  passwordHash String
  fullName     String
  role         UserRole     @default(STUDENT)
  status       UserStatus   @default(ACTIVE)
  paymentStatus PaymentStatus @default(PENDING)
  profile      UserProfile?
  enrollments  Enrollment[]
  lessonProgress LessonProgress[]
  submissions    Submission[]
  attempts       Attempt[]
  competitionParticipations CompetitionParticipant[]
  competitionAttempts       CompetitionAttempt[]
  createdTeams              Team[]                   @relation("TeamCreator")
  teamMemberships           TeamMember[]
  attendanceRecords         AttendanceRecord[]
  loginLogs    LoginLog[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model UserProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  gender               String?
  country              String?
  state                String?
  lga                  String?
  community            String?
  institution          String?
  profession           String?
  highestQualification String?
  preferredMode        String?
  avatarUrl            String?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginLog {
  id        String   @id @default(uuid())
  userId    String?
  email     String?
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Course {
  id              String       @id @default(uuid())
  code            String       @unique
  title           String
  description     String?
  level           Int?
  deliveryMode    DeliveryMode
  requiresPayment Boolean      @default(true)
  isArchived      Boolean      @default(false)
  lessons         Lesson[]
  classes         Class[]
  enrollments     Enrollment[]
  assignments     Assignment[]
  assessments     Assessment[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Lesson {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  summary     String?
  order       Int
  videoUrl    String?
  resourceUrl String?
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
}

model Class {
  id        String       @id @default(uuid())
  courseId  String
  name      String
  mode      DeliveryMode
  startsAt  DateTime?
  endsAt    DateTime?
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  students  Enrollment[]
  attendanceRecords AttendanceRecord[]
}

model Enrollment {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  classId    String?
  progress   Int      @default(0)
  points     Int      @default(0)
  enrolledAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  class      Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)

  @@unique([userId, courseId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model AttendanceRecord {
  id        String           @id @default(uuid())
  classId   String
  userId    String
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  note      String?
  class     Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([classId, userId, date])
  @@index([classId, date])
}

model LessonProgress {
  id          String   @id @default(uuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Assignment {
  id          String       @id @default(uuid())
  courseId    String
  title       String
  description String?
  dueDate     DateTime?
  maxScore    Int          @default(100)
  isPublished Boolean      @default(false)
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions Submission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
  RETURNED
}

model Submission {
  id           String           @id @default(uuid())
  assignmentId String
  studentId    String
  answer       String?
  fileUrl      String?
  status       SubmissionStatus @default(SUBMITTED)
  score        Int?
  feedback     String?
  submittedAt  DateTime         @default(now())
  gradedAt     DateTime?
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  TIMED_OUT
}

model Assessment {
  id               String      @id @default(uuid())
  courseId         String?
  title            String
  description      String?
  durationMin      Int         @default(30)
  passMark         Int         @default(50)
  totalPoints      Int         @default(100)
  shuffleQuestions Boolean     @default(false)
  isPublished      Boolean     @default(false)
  course           Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  questions        Question[]
  attempts         Attempt[]
  competitions     Competition[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Question {
  id            String       @id @default(uuid())
  assessmentId  String
  text          String
  type          QuestionType @default(MCQ)
  /// JSON array of strings for MCQ options; empty for TRUE_FALSE / SHORT_ANSWER
  options       Json         @default("[]")
  /// For MCQ: the correct option string. For TRUE_FALSE: "true" or "false". For SHORT_ANSWER: null (manual or keyword match)
  correctAnswer String?
  points        Int          @default(1)
  order         Int          @default(0)
  explanation   String?
  assessment    Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, order])
}

model Attempt {
  id           String        @id @default(uuid())
  assessmentId String
  userId       String
  /// JSON object: { questionId: answerString }
  answers      Json          @default("{}")
  score        Int?
  maxScore     Int?
  percentage   Int?
  passed       Boolean?
  status       AttemptStatus @default(IN_PROGRESS)
  startedAt    DateTime      @default(now())
  submittedAt  DateTime?
  assessment   Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assessmentId, userId])
}

model Competition {
  id              String            @id @default(uuid())
  title           String
  description     String?
  mode            CompetitionMode
  status          CompetitionStatus @default(DRAFT)
  /// Optional link to an Assessment for its question bank
  assessmentId    String?
  assessment      Assessment?       @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  durationMin     Int               @default(30)
  maxParticipants Int?
  isPublic        Boolean           @default(true)
  /// Passphrase required to join when isPublic = false
  joinCode        String?
  startsAt        DateTime?
  endsAt          DateTime?
  participants    CompetitionParticipant[]
  competitionAttempts CompetitionAttempt[]
  leaderboard     LeaderboardEntry[]
  teams           Team[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model CompetitionParticipant {
  id            String      @id @default(uuid())
  competitionId String
  userId        String
  teamId        String?
  score         Int         @default(0)
  rank          Int?
  joinedAt      DateTime    @default(now())
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team          Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([competitionId, userId])
  @@index([competitionId, score])
  @@index([teamId])
}

model Team {
  id            String      @id @default(uuid())
  competitionId String
  name          String
  code          String?
  score         Int         @default(0)
  rank          Int?
  createdById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  createdBy     User?       @relation("TeamCreator", fields: [createdById], references: [id], onDelete: SetNull)
  members       TeamMember[]
  participants  CompetitionParticipant[]

  @@unique([competitionId, name])
  @@index([competitionId, score])
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  userId   String
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model CompetitionAttempt {
  id            String      @id @default(uuid())
  competitionId String
  userId        String
  /// JSON object: { questionId: answerString }
  answers       Json        @default("{}")
  score         Int?
  maxScore      Int?
  percentage    Int?
  durationSec   Int?
  submittedAt   DateTime?
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([competitionId, userId])
}

model LeaderboardEntry {
  id            String      @id @default(uuid())
  competitionId String
  participantId String
  participant   String
  score         Int
  rank          Int?
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
}

model Certificate {
  id             String   @id @default(uuid())
  certificateNo  String   @unique
  userId         String
  title          String
  verificationId String   @unique
  issuedAt       DateTime @default(now())
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
